# --- ChainMind Environment Variables Setup ---
# Copy this file to .env in the backend/ folder and other locations as needed.

# ==========================================
# 1. AI API KEYS (Choose at least one)
# ==========================================

# Google Gemini: Used for attack simulation and code analysis.
# GET KEY: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# Groq: Used for fast secondary reasoning or Llama models.
# GET KEY: https://console.groq.com/keys
GROQ_API_KEY=your_groq_api_key_here

# Mistral AI: Used for code-specialized reasoning.
# GET KEY: https://console.mistral.ai/api-keys/
MISTRAL_API_KEY=your_mistral_api_key_here


# ==========================================
# 2. BLOCKCHAIN & WALLET (Celo Alfajores)
# ==========================================

# Private Key: Your wallet's private key for deploying and signing transactions.
# IMPORTANT: Use a NEW test wallet. Never use your main wallet!
# HOW TO GET:
#   - Export from MetaMask (Account Details -> Export Private Key)
#   - Make sure you have test Celo from: https://faucet.celo.org/
PRIVATE_KEY=0x_your_private_key_here

# Celo RPC URL: The network endpoint
CELO_RPC_URL=https://alfajores-forno.celo-testnet.org


# ==========================================
# 3. SMART CONTRACT ADDRESSES
# ==========================================
# These are generated after you run 'forge script script/Deploy.s.sol'

# Main Infrastructure Registry
REGISTRY_ADDRESS=0x_deployed_main_registry_address

# ERC-8004 Identity (The Agent's Identity on-chain)
ERC8004_IDENTITY_REGISTRY=0x_deployed_identity_registry_address

# ERC-8004 Reputation (The Agent's feedback system)
ERC8004_REPUTATION_REGISTRY=0x_deployed_reputation_registry_address

# Payment Gateway (Where users pay for audits)
PAYMENT_GATEWAY_ADDRESS=0x_deployed_payment_gateway_address

# cUSD Token on Alfajores (Standard: 0x874069Fa1Eb16D44d622F2e0Ca25eeA172369bC1)
CUSD_TOKEN_ADDRESS=0x874069Fa1Eb16D44d622F2e0Ca25eeA172369bC1


# ==========================================
# 4. AGENT SETTINGS
# ==========================================
AGENT_NAME=ChainMind
AGENT_DESCRIPTION=Autonomous AI smart contract security auditor on Celo
