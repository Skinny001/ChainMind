# SMART CONTRACT DEPLOYMENT VARIABLES
# -----------------------------------

# Private Key for deploying contracts to Celo Alfajores
# HOW TO GET: MetaMask -> Account Details -> Export Private Key
# IMPORTANT: Never commit your actual .env file with this key!
PRIVATE_KEY=0x_your_private_key_here

# RPC URL for deployment
RPC_URL=https://alfajores-forno.celo-testnet.org

# Optional: Block explorer API key for contract verification (CeloScan)
# Get one at: https://celoscan.io/myapikey
CELOSCAN_API_KEY=your_celoscan_api_key_here

# Etherscan API key (for other networks if applicable)
ETHERSCAN_API_KEY=DK3H3XHG9VVEZPY1U3GYVIIJGCHU5U9H39
