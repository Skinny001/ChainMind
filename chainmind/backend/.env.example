# BACKEND ENVIRONMENT VARIABLES
# -----------------------------

# AI API KEYS (Choose at least one)
# Gemini: https://aistudio.google.com/app/apikey (Required for attack simulation)
GEMINI_API_KEY=

# Groq: https://console.groq.com/keys
GROQ_API_KEY=

# Mistral AI: https://console.mistral.ai/api-keys/
MISTRAL_API_KEY=


# BLOCKCHAIN CONFIGURATION (Celo Alfajores)
# Private Key for signing Agent Identity & Reputation
PRIVATE_KEY=0x_your_private_key_here

# Celo RPC URL
CELO_RPC_URL=https://alfajores-forno.celo-testnet.org


# SMART CONTRACT ADDRESSES (ERC-8004 Infrastructure)
# Run 'forge script script/Deploy.s.sol' to get these addresses
REGISTRY_ADDRESS=0x_deployed_main_registry_address
ERC8004_IDENTITY_REGISTRY=0x_deployed_identity_registry_address
ERC8004_REPUTATION_REGISTRY=0x_deployed_reputation_registry_address
PAYMENT_GATEWAY_ADDRESS=0x_deployed_payment_gateway_address

# Standard cUSD address on Alfajores
CUSD_TOKEN_ADDRESS=


# AGENT SETTINGS
AGENT_NAME=ChainMind
AGENT_DESCRIPTION=Autonomous AI smart contract security auditor on Celo
